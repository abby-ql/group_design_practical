# Copy to .env and edit as needed
DATABASE_URL=sqlite:///./reputation_demo.db

# Trend ingestion sources
# Choose: "newsapi" | "rss"
TRENDS_SOURCE=rss

# NewsAPI (optional)
NEWSAPI_KEY=
NEWSAPI_COUNTRY=gb
NEWSAPI_PAGE_SIZE=50

# RSS (fallback, no key needed)
# BBC UK RSS is a convenient demo source. If you need open-licensed sources, swap this to GOV.UK/ONS feeds.
RSS_URL=https://feeds.bbci.co.uk/news/uk/rss.xml

# GOV.UK Atom feed for news & communications (may require additional params in some environments)
GOVUK_ATOM_URL=https://www.gov.uk/search/news-and-communications.atom

# Cross-match / scoring
TREND_HALF_LIFE_HOURS=48
